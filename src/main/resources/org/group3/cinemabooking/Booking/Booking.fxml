<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="756.0" prefWidth="1150.0" stylesheets="@../CSS/Booking/Booking.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.group3.cinemabooking.Booking.BookingController">
    <HBox alignment="CENTER" prefHeight="56.0" prefWidth="1150.0">
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="1103.0">
            <Label prefHeight="56.0" prefWidth="988.0" text="ShowTimes" textFill="WHITE">
                <font>
                    <Font name="Lato Black" size="30.0"/>
                </font>
            </Label>
            <TextField prefHeight="23.0" prefWidth="207.0" promptText="Search Your Things" styleClass="searchMovieLb"/>
        </HBox>
    </HBox>
    <HBox fx:id="hBoxShowTimes" alignment="CENTER" prefHeight="300.0" prefWidth="200.0" spacing="32.0"/>
    <HBox alignment="CENTER" prefHeight="56.0" prefWidth="1150.0">
        <HBox alignment="CENTER" prefHeight="100.0" prefWidth="1103.0">
            <Label prefHeight="56.0" prefWidth="1062.0" text="ComingSoon" textFill="WHITE">
                <font>
                    <Font name="Lato Black" size="30.0"/>
                </font>
            </Label>
            <Label alignment="CENTER_RIGHT" onMouseClicked="#onSeeAllCSMovie" prefHeight="15.0" prefWidth="41.0"
                   styleClass="seeAllLb" text="See All"/>
        </HBox>
    </HBox>
    <HBox fx:id="hBoxComingSoon" alignment="CENTER" prefHeight="300.0" prefWidth="200.0" spacing="32.0"/>
</VBox>
